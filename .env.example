# === Scanner (legacy) ===
CONFIG_FILE=./config.yaml

# === Database ===
DATABASE_URL=postgresql+asyncpg://nis2:nis2secret@postgres:5432/nis2
DATABASE_URL_SYNC=postgresql://nis2:nis2secret@postgres:5432/nis2
POSTGRES_USER=nis2
POSTGRES_PASSWORD=nis2secret
POSTGRES_DB=nis2

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === JWT ===
# IMPORTANT: Generate a real secret before deploying!
# Run: openssl rand -base64 32
JWT_SECRET=GENERATE_ME_openssl_rand_base64_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# === Celery ===
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# === NextAuth ===
# Run: openssl rand -base64 32
NEXTAUTH_SECRET=GENERATE_ME_openssl_rand_base64_32

# === API ===
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# === Caddy (production) ===
DOMAIN=nis2.yourdomain.com
