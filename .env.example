# === Environment ===
# "production" (default; enforces strict secret and CORS validation at boot)
# or "development" (relaxed defaults, localhost CORS fallback).
ENVIRONMENT=production

# === Database ===
DATABASE_URL=postgresql+asyncpg://nis2:nis2secret@postgres:5432/nis2
DATABASE_URL_SYNC=postgresql://nis2:nis2secret@postgres:5432/nis2
POSTGRES_USER=nis2
POSTGRES_PASSWORD=nis2secret
POSTGRES_DB=nis2

# === Redis ===
REDIS_URL=redis://redis:6379/0
# Required by infra/docker/docker-compose.prod.yml (redis-server --requirepass).
REDIS_PASSWORD=changeme

# === JWT ===
# REQUIRED in production. Generate: openssl rand -base64 32
# The API refuses to start in production if this is unset, equals "change-me",
# or is shorter than 32 characters.
JWT_SECRET=GENERATE_ME_openssl_rand_base64_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# === Celery ===
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# === NextAuth ===
# Run: openssl rand -base64 32
NEXTAUTH_SECRET=GENERATE_ME_openssl_rand_base64_32

# === API ===
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# === CORS ===
# REQUIRED in production. Comma-separated allow-list, no wildcards.
# Example: CORS_ORIGINS=https://nis2.example.com,https://app.nis2.example.com
CORS_ORIGINS=

# === Caddy (production) ===
DOMAIN=nis2.yourdomain.com
