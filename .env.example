# ============================================================================
# NIS2 Compliance Platform — Environment Configuration
# ============================================================================
# COPY this file to .env and fill in the values before starting.
#
# P0-07 audit fix (v2.5.5): this file now uses PLACEHOLDER values
# instead of working dev credentials. A bare `cp .env.example .env`
# will NOT produce a bootable stack — you MUST replace the placeholders.
# This is intentional: it prevents accidentally committing real secrets
# and forces explicit configuration on every new checkout.
# ============================================================================

# === Environment ===
# "development" or "production". Production mode REFUSES to start unless:
#   - JWT_SECRET is set, >= 32 chars, and not a placeholder
#   - CORS_ORIGINS is non-empty (comma-separated allow-list, no wildcards)
ENVIRONMENT=development

# === Database ===
# `postgres:5432` resolves via Docker DNS inside the compose network.
# For host-side tools (pytest, alembic, REPL) use localhost:5433 instead.
DATABASE_URL=postgresql+asyncpg://nis2:CHANGE_ME_DB_PASSWORD@postgres:5432/nis2
DATABASE_URL_SYNC=postgresql://nis2:CHANGE_ME_DB_PASSWORD@postgres:5432/nis2
POSTGRES_USER=nis2
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=nis2

# === Redis ===
# Production runs `redis-server --requirepass $REDIS_PASSWORD`, so the URL MUST
# embed the same password (userless `:password@host`). Keep it in sync with
# REDIS_PASSWORD below or the stack never goes healthy (Redis returns NOAUTH).
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0
# Required by docker-compose.prod.yml (redis-server --requirepass).
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# === JWT ===
# REQUIRED. Generate with: openssl rand -base64 32
# The API refuses to start in production if this is unset or a placeholder.
JWT_SECRET=CHANGE_ME_RUN_openssl_rand_base64_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# === Field encryption ===
# Keys field-level encryption of MFA/TOTP secrets (AES-GCM). Independent of
# JWT_SECRET. When unset, the key is derived from JWT_SECRET for backward
# compatibility — fine for HS256. In RS256 mode there is NO JWT_SECRET, so this
# is REQUIRED in production (the API refuses to start without it).
# Generate with: openssl rand -base64 32
# NOTE: changing this on an existing deployment makes already-stored TOTP
# secrets undecryptable — affected users must re-enroll MFA.
DATA_ENCRYPTION_KEY=

# === Celery ===
CELERY_BROKER_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/2

# === NextAuth ===
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_RUN_openssl_rand_base64_32

# === API ===
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# === AI remediation (OPTIONAL — off by default) ===
# The "Explain finding" copilot can call a local LLM (Ollama/LM Studio) or
# OpenAI. The local LLM stays on-prem. OpenAI egress is DISABLED unless you set
# ENABLE_OPENAI=true — setting only OPENAI_API_KEY is no longer enough.
# PRIVACY: enabling OpenAI sends finding text (which may contain internal
# hostnames, leaked secrets, incidental PII) to api.openai.com in the USA — a
# transborder flow you must disclose in your privacy notice (docs/privacy.md §7.3).
LLM_API_URL=http://localhost:1234/v1
OPENAI_API_KEY=
ENABLE_OPENAI=false

# === CORS ===
# REQUIRED in production. Comma-separated allow-list, no wildcards.
# Example: CORS_ORIGINS=https://nis2.example.com,https://app.nis2.example.com
CORS_ORIGINS=

# === Caddy (production) ===
DOMAIN=nis2.yourdomain.com
